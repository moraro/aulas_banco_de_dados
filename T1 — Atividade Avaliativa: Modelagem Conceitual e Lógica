Table usuarios{
  id_usuario int [pk] 
  email_usuario varchar [unique]
  cpf varchar [unique]
  data_nascimento date
  nome_exibicao varchar
}

Table enderecos{
  id_endereco int [pk]
  endereco_usuario varchar 
  usuario_id int 
}

Ref {usuarios.id_usuario < enderecos.usuario_id}

Table planos{
  id_plano int [pk]
  preco_plano float
  qualidade_audio varchar
  qualidade_video varchar
  tela_simultanias varchar
  planos_usuarios_id int
}

Table plano_usuarios{
  id_plano_usuario int [pk]
  usuario_id int
  data_inicio date
  data_fim date
  status varchar
}

Ref {plano_usuarios.usuario_id > usuarios.id_usuario}
Ref {planos.planos_usuarios_id > plano_usuarios.id_plano_usuario}

Table idiomas {
  id_idioma int [pk]
  idioma_legenda varchar
  idioma_audio varchar
  usuario_id int
}

Ref {idiomas.usuario_id > usuarios.id_usuario}

Table conteudos{
  id_conteudo int [pk]
  tipo_conteudo varchar
  titulo_conteudo varchar
  duracao_conteudo seconds
  data_lancamento date
  genero_id int
}

Table generos {
  id_genero int [pk]
  genero_conteudo varchar
}

Ref {conteudos.genero_id > generos.id_genero}

Table musicas {
  id_musica int [pk]
  nome_musica varchar
  letra_musica text
  conteudo_id int
}

Ref {conteudos.id_conteudo - musicas.conteudo_id}

Table albuns {
  id_album int [pk]
  nome_album varchar
  data_lancamento date
  img_capa varchar
  artista_id int
  musica_id int
}

Table artistas{
  id_artista int [pk]
  nome_artistico varchar
  pais_origem varchar
  biografia text
}

Table nome_artistas{
  id_nome_artista int [pk]
  nome_artista varchar
  artista_id int
}

Ref {musicas.id_musica - albuns.musica_id}
Ref {artistas.id_artista - albuns.artista_id}
Ref {artistas.id_artista < nome_artistas.artista_id}

Table filmes{
  id_filme int [pk]
  sinopse text
  classificacao_et varchar
  conteudo_id int
  diretor_id int
}

Ref {conteudos.id_conteudo - filmes.conteudo_id}

Table diretores{
  id_diretor int [pk]
  nome_diretor varchar
  data_nascimento_diretor date
  nacionalidade_diretor varchar
}

Table atores{
  id_ator int [pk]
  nome_autor varchar
  data_nascimento_autor date
  nacionalidade_autor varchar
  nome_personagem varchar
  posicao_creditos varchar
  filme_id int
}

Ref {filmes.diretor_id > diretores.id_diretor}
Ref {filmes.id_filme > atores.filme_id}

Table series{
  id_series int [pk]
  titulo_serie varchar
  sinopse_serie text
  classificacao_et varchar
  status_producao varchar
  conteudo_id int
}

Table temporadas{
  id_temporada int [pk]
  serie_id int
  numero_ordem_temporada int
  ano_lancamento_temporada year 
}

Ref {series.id_series < temporadas.serie_id}
Ref {conteudos.id_conteudo - series.conteudo_id}

Table episodios{
  id_episodios int [pk]
  temporada_id int
  numero_ordem_episodio int
  sinopse text 
}

Ref {temporadas.id_temporada < episodios.temporada_id}

Table playlists{
  id_playlist int [pk]
  nome_playlist varchar
  descricao_playlist text
  visibilidade_playlist varchar
  data_criacao date
  ordem_playlist int  
  seguidores int
  data_seguidor date
  usuario_id int
  conteudo_id int
}

Ref{usuarios.id_usuario < playlists.usuario_id}
Ref{conteudos.id_conteudo < playlists.conteudo_id}
